    {"trigger": "AI decision NEED_APPROVAL", "reason_code": "need_approval", "condition": "result.decision === 'NEED_APPROVAL'", "expected": "Handoff; reply_text sent; summary"},
    {"trigger": "Agent call failed", "reason_code": "ai_agent_failed", "condition": "!result", "expected": "Handoff; no reply_text"},
    {"trigger": "Booking API failed", "reason_code": "booking_failed", "condition": "create_appointment threw", "expected": "Handoff; booking_failed message to client"},
    {"trigger": "Fake confirmation", "reason_code": "fake_confirmation_blocked", "condition": "reply looks confirmed but no create success", "expected": "Handoff; booking_not_confirmed_fallback to client"},
    {"trigger": "Policy: handoff disallowed", "reason_code": "—", "condition": "allow_agent_to_create_handoff false", "expected": "No handoff; reply only or generic_ack"},
    {"trigger": "Legacy (no AI)", "reason_code": "legacy_handoff", "condition": "Trigger words or force_handoff", "expected": "Handoff with summary"}
  ],
  "smokeRespond": [
    {"condition": "RESPOND, allow_agent_to_reply true, reply_text present", "expected": "Send reply_text to client"},
    {"condition": "RESPOND, allow_agent_to_reply true, no reply_text", "expected": "Send generic_ack"},
    {"condition": "RESPOND, allow_agent_to_reply false", "expected": "Send generic_ack only; reply_blocked event"},
    {"condition": "RESPOND, mutating tool, allow_agent_to_execute true", "expected": "Execute tool; tool_succeeded / tool_failed event"},
    {"condition": "RESPOND, mutating tool, allow_agent_to_execute false", "expected": "Skip tool; execution_denied_by_policy event"}
