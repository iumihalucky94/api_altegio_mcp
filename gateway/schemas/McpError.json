{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "McpError",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "enum": [
        "VALIDATION_ERROR",
        "MULTIPLE_CLIENTS_FOUND",
        "CLIENT_NOT_FOUND",
        "APPOINTMENT_NOT_FOUND",
        "POLICY_DENY",
        "APPROVAL_REQUIRED",
        "APPROVAL_INVALID",
        "RATE_LIMIT",
        "UPSTREAM_ALTEGIO_ERROR",
        "INTERNAL_ERROR"
      ]
    },
    "message": { "type": "string" },
    "details": { "type": "object" }
  }
}
