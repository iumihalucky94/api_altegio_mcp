NODE_ENV=development

# Gateway
GATEWAY_PORT=3030

# Admin / approvals
ADMIN_APPROVE_KEY=please-change-me

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=altegio_mcp
POSTGRES_USER=altegio_mcp
POSTGRES_PASSWORD=altegio_mcp_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=2
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=5

# Timeouts (ms)
GATEWAY_REQUEST_TIMEOUT_MS=15000
ALTEGIO_HTTP_TIMEOUT_MS=8000
OPERATION_BUDGET_MS=20000

# Altegio API
ALTEGIO_BASE_URL=https://api.alteg.io
ALTEGIO_API_VERSION=b2b-v1
ALTEGIO_PARTNER_TOKEN=your-partner-token-here
ALTEGIO_USER_TOKEN=your-user-token-here

# Orchestrator (transport-agnostic; Telegram admin)
ORCHESTRATOR_PORT=3031
MCP_GATEWAY_URL=http://localhost:3030
# URL wa-service для отправки ответов в WhatsApp (если не задан — используется MCP_GATEWAY_URL)
WA_SEND_URL=http://localhost:3032
# Токен для MCP и для ingest/send WhatsApp (orchestrator + wa-service)
MCP_INTERNAL_TOKEN=

# Telegram: токен от @BotFather; ID групп — из getUpdates после сообщения в группе
TELEGRAM_BOT_TOKEN=
TG_LOGS_GROUP_CHAT_ID=          # группа для логов (ошибки, ADMIN_ONLY)
TG_SUMMARY_GROUP_CHAT_ID=       # группа для саммари (хендофы, напоминания)

# wa-service (отдельный контейнер): WhatsApp Web. ORCHESTRATOR_INGEST_URL и WA_INTERNAL_TOKEN в docker-compose / .env.
WA_SERVICE_PORT=3032

DEFAULT_COMPANY_ID=1169276

# AI Agent (SISI Beauty Bar — ChatGPT/OpenAI). Пишите ключ и URL без комментариев в той же строке (иначе значение испортится).
OPENAI_API_KEY=
AI_AGENT_API_BASE_URL=https://api.openai.com/v1
AI_AGENT_MODEL=gpt-4o-mini

# Knowledge Base (KB) for AI agent
KB_INTERNAL_TOKEN=
KB_MODE=embedded             # embedded | service (only embedded implemented now)
KB_CONTEXT_LIMIT_TEMPLATES=3
KB_CONTEXT_LIMIT_GOOD_EXAMPLES=3
KB_CONTEXT_LIMIT_BAD_EXAMPLES=1
KB_CONTEXT_MAX_CHARS=2500

# Audit log retention (days)
AUDIT_RETENTION_DAYS=180

# Ограничение по номерам: обрабатывать только из списка (true) или всех (false).
ALLOW_ONLY_LISTED_PHONES=false
# Список разрешённых номеров через запятую (E.164). Используется только если ALLOW_ONLY_LISTED_PHONES=true.
ALLOWED_PHONE_LIST=+4367762665083

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

